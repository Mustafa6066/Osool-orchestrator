# ═══════════════════════════════════════════════════════════════
# Osool Orchestrator — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# === REQUIRED ===

# Database
DATABASE_URL=postgresql://osool:osool_dev_2025@localhost:5432/osool

# Redis
REDIS_URL=redis://localhost:6379

# AI (required for content generation + intent parsing)
ANTHROPIC_API_KEY=sk-ant-...

# Email (required for email sequences)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@osool.ai

# Admin Auth
ADMIN_JWT_SECRET=generate-a-64-char-random-string
ADMIN_EMAIL=admin@osool.ai
ADMIN_PASSWORD_HASH=  # Generated by scripts/create-admin.ts

# Webhook Auth (shared secret with frontend)
WEBHOOK_SECRET=generate-a-64-char-random-string

# API Key (for frontend data requests)
API_KEY=generate-a-64-char-random-string

# === OPTIONAL (stubbed if not provided) ===

# Meta Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# === APP CONFIG ===

PORT=4000
ADMIN_PORT=5173
ALLOWED_ORIGINS=https://osool-ten.vercel.app,http://localhost:3000,http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info
CAIRO_TIMEZONE=Africa/Cairo
